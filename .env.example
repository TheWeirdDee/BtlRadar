# BTL Runtime (get from runtime.badtheorylabs.com after registering for hackathon)
BTL_API_KEY=BTL_your_key_here

# Supabase (RetainDB simulation — get from supabase.com, free tier)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Blockchain data feeds
ALCHEMY_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/your_alchemy_key
ALCHEMY_API_KEY=your_alchemy_api_key
HELIUS_API_KEY=your_helius_api_key

# Telegram bot (get token from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# X / Twitter API v2 (apply at developer.twitter.com)
X_BEARER_TOKEN=your_bearer_token
X_API_KEY=your_api_key
X_API_SECRET=your_api_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_SECRET=your_access_secret

# App
NEXT_PUBLIC_APP_URL=https://btl-radar.vercel.app
NODE_ENV=development
